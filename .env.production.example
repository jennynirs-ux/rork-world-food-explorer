# ── Production environment ──────────────────────────────────────
# Copy to .env.production and fill in REAL values before running
# a production build:  eas build --profile production
#
# IMPORTANT: Never commit this file with real keys.
# The .gitignore already excludes .env.production.

# Backend API base URL (required)
EXPO_PUBLIC_RORK_API_BASE_URL=https://api.worldfoodexplorer.app

# RevenueCat API keys — use PRODUCTION keys here
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_YOUR_PRODUCTION_IOS_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_YOUR_PRODUCTION_ANDROID_KEY

# Backend API key (required in production)
WFE_API_KEY=your_production_api_key_here
