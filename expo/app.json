{
  "expo": {
    "name": "World Food Journey",
    "slug": "world-food-journey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "worldfoodexplorer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rork.world-food-explorer",
      "infoPlist": {
        "SKStoreReviewController": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {}
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "app.rork.world_food_explorer",
      "permissions": [
        "android.permission.VIBRATE",
        "com.android.vending.BILLING",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "mode": "production"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "World Food Journey uses your photo library so you can add cooking photos to your recipes.",
          "cameraPermission": "World Food Journey uses your camera so you can take photos of your finished dishes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "jenny.nirs",
    "extra": {
      "eas": {
        "projectId": "eee3cf65-e133-4862-a605-c354a4003ee0"
      }
    }
  }
}
