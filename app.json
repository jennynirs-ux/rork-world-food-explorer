{
  "expo": {
    "name": "World Food Explorer",
    "slug": "world-food-explorer",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "worldfoodexplorer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rork.world-food-explorer",
      "infoPlist": {
        "SKStoreReviewController": true
      },
      "entitlements": {
        "com.apple.developer.in-app-payments": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "app.rork.world_food_explorer",
      "permissions": [
        "android.permission.VIBRATE",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://worldfoodexplorer.app/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "privacyPolicyUrl": "https://worldfoodexplorer.app/privacy",
      "termsOfServiceUrl": "https://worldfoodexplorer.app/terms"
    }
  }
}
