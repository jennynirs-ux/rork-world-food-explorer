# Backend API base URL (required)
EXPO_PUBLIC_RORK_API_BASE_URL=https://your-backend.example.com

# RevenueCat API keys (required for monetization)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_YOUR_IOS_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_YOUR_ANDROID_KEY

# Backend API key (required in production — protects all API routes)
WFE_API_KEY=

# RevenueCat SECRET key (required in production for server-side purchase verification)
# Find this in RevenueCat Dashboard → Project Settings → API Keys → Secret key
# This is NOT the same as the public SDK keys above.
WFE_REVENUECAT_SECRET_KEY=
